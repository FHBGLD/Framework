{
    "name": "hawb/framework",
    "description": "MVC Framework for all new developtments of hawb",
    "type": "library",
    "license": "MIT",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "Hawb\\Framework\\": "src/"
        }
    },
    "authors": [
        {
            "name": "Martin Fiebrich-Christ",
            "email": "martin.fiebrich-christ@hochschule-burgenland.at"
        }
    ],
    "require": {
        "vlucas/phpdotenv": "~5.6.3",
        "twig/twig": "~3.24.0"
    },
    "require-dev": {
        "pestphp/pest": "~4.4.2"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
